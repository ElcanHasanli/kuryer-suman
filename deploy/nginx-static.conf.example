# courier.suman.khamsacraft.az — Next.js static export (out/)
# Bütün out/ qovluğunu serverə yükləyin: npm run build && rsync out/ ...

server {
    listen 443 ssl http2;
    server_name courier.suman.khamsacraft.az;

    root /var/www/courier-suman/out;
    index index.html;

    location /_next/ {
        alias /var/www/courier-suman/out/_next/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    location / {
        try_files $uri $uri/ $uri/index.html =404;
    }
}
